# ─────────────────────────────────────────
# 데이터베이스 (MySQL)
# ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=yebija
DB_PASSWORD=yebija1234

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-string-at-least-32-characters-long

# ─────────────────────────────────────────
# CORS
# ─────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─────────────────────────────────────────
# 파일 업로드
# ─────────────────────────────────────────
STORAGE_TYPE=local
FILE_UPLOAD_PATH=/tmp/yebija/uploads

# ─────────────────────────────────────────
# OpenAI (Phase 2)
# ─────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────
# 서버
# ─────────────────────────────────────────
PORT=8080

# ─────────────────────────────────────────
# Spring Profiles Active
# ─────────────────────────────────────────
SPRING_PROFILES_ACTIVE=local